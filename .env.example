# ---------------------------------------------------------------
# SMTP — REQUIRED for the contact & quote forms to send email.
#
# IMPORTANT: the old WordPress site had NO SMTP set up. It used PHP mail()
# and its stored mail settings were still WordPress's stock placeholders
# (mail.example.com / login@example.com / port 110). There were no real
# credentials to carry over, so these must be filled in fresh.
#
# On Replit, put these in the Secrets tab (lock icon) — NOT in a committed file.
#
# Option A — Hostinger mailbox for info@gusjov.com (your domain is hosted there):
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=465
#   SMTP_USER=info@gusjov.com
#   SMTP_PASS=<the mailbox password from hPanel > Emails>
#
# Option B — Gmail (needs an App Password, not your normal password:
#            https://myaccount.google.com/apppasswords):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=martinezdigital25@gmail.com
#   SMTP_PASS=<16-character app password>
# ---------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Who the mail is FROM. Must be a mailbox your SMTP account may send as.
MAIL_FROM=info@gusjov.com

# Where form submissions land. Defaults to SMTP_USER if unset.
MAIL_TO=info@gusjov.com

PORT=3000
