run = "npm run serve"
entrypoint = "src/App.jsx"
modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "npm run serve"]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm install && npm run build"]

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 3000

[env]
NODE_ENV = "production"
